---
// Переопределение Starlight Header: оригинальная разметка + две кнопки,
// сворачивающие левую (навигация) и правую («На этой странице») панели.
// Кнопки добавлены внутрь существующих колонок грида, чтобы не ломать его.
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="header">
	<div class="title-wrapper sl-flex">
		<button
			type="button"
			class="sidebar-toggle sidebar-toggle--left"
			aria-pressed="false"
			aria-label="Свернуть боковое меню"
			title="Свернуть/показать боковое меню"
		>
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="3" y="4" width="18" height="16" rx="2"></rect>
				<line x1="9" y1="4" x2="9" y2="20"></line>
			</svg>
		</button>
		<SiteTitle />
	</div>
	<div class="sl-flex print:hidden">
		{shouldRenderSearch && <Search />}
	</div>
	<div class="sl-hidden md:sl-flex print:hidden right-group">
		<div class="sl-flex social-icons">
			<SocialIcons />
		</div>
		<ThemeSelect />
		<LanguageSelect />
		<button
			type="button"
			class="sidebar-toggle sidebar-toggle--right"
			aria-pressed="false"
			aria-label="Свернуть оглавление страницы"
			title="Свернуть/показать оглавление страницы"
		>
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="3" y="4" width="18" height="16" rx="2"></rect>
				<line x1="15" y1="4" x2="15" y2="20"></line>
			</svg>
		</button>
	</div>
</div>

<style>
	@layer starlight.core {
		.header {
			display: flex;
			gap: var(--sl-nav-gap);
			justify-content: space-between;
			align-items: center;
			height: 100%;
		}

		.title-wrapper {
			/* Prevent long titles overflowing and covering the search and menu buttons on narrow viewports. */
			overflow: clip;
			/* Avoid clipping focus ring around link inside title wrapper. */
			padding: 0.25rem;
			margin: -0.25rem;
			min-width: 0;
			align-items: center;
			gap: 0.5rem;
		}

		.right-group,
		.social-icons {
			gap: 1rem;
			align-items: center;
		}
		.social-icons::after {
			content: '';
			height: 2rem;
			border-inline-end: 1px solid var(--sl-color-gray-5);
		}

		@media (min-width: 50rem) {
			:global(:root[data-has-sidebar]) {
				--__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
			}
			:global(:root:not([data-has-toc])) {
				--__toc-width: 0rem;
			}
			.header {
				--__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
				--__main-column-fr: calc(
					(
							100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
								(2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
								var(--sl-content-width)
						) / 2
				);
				display: grid;
				grid-template-columns:
        /* 1 (site title): runs up until the main content column’s left edge or the width of the title, whichever is the largest  */
					minmax(
						calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))),
						auto
					)
					/* 2 (search box): all free space that is available. */
					1fr
					/* 3 (right items): use the space that these need. */
					auto;
				align-content: center;
			}
		}
	}

	/* Кнопки-переключатели панелей */
	.sidebar-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 2rem;
		height: 2rem;
		padding: 0;
		border: 0;
		border-radius: 0.375rem;
		background: transparent;
		color: var(--sl-color-text);
		cursor: pointer;
	}
	.sidebar-toggle:hover {
		background: var(--sl-color-gray-6, var(--sl-color-gray-5));
		color: var(--sl-color-white);
	}
	.sidebar-toggle[aria-pressed='true'] {
		color: var(--sl-color-text-accent);
	}

	/* Левую кнопку показываем только на десктопе и только когда есть боковое меню */
	:global(:root[data-has-sidebar]) .sidebar-toggle--left {
		display: none;
	}
	@media (min-width: 50rem) {
		:global(:root[data-has-sidebar]) .sidebar-toggle--left {
			display: inline-flex;
		}
	}

	/* Правую кнопку — только когда есть оглавление (оно показывается с 72rem) */
	.sidebar-toggle--right {
		display: none;
	}
	@media (min-width: 72rem) {
		:global(:root[data-has-toc]) .sidebar-toggle--right {
			display: inline-flex;
		}
	}
</style>

<script>
	function initSidebarToggles() {
		const root = document.documentElement;
		const left = document.querySelector('.sidebar-toggle--left');
		const right = document.querySelector('.sidebar-toggle--right');

		const KEY_LEFT = 'edu:hide-left';
		const KEY_RIGHT = 'edu:hide-right';

		function sync(btn, attr) {
			if (btn) btn.setAttribute('aria-pressed', root.hasAttribute(attr) ? 'true' : 'false');
		}

		// Применяем сохранённое состояние (на случай навигации без перезагрузки)
		try {
			if (localStorage.getItem(KEY_LEFT) === '1') root.setAttribute('data-user-hide-left', '');
			if (localStorage.getItem(KEY_RIGHT) === '1') root.setAttribute('data-user-hide-right', '');
		} catch {}
		sync(left, 'data-user-hide-left');
		sync(right, 'data-user-hide-right');

		left?.addEventListener('click', () => {
			const hidden = root.toggleAttribute('data-user-hide-left');
			try {
				localStorage.setItem(KEY_LEFT, hidden ? '1' : '0');
			} catch {}
			sync(left, 'data-user-hide-left');
		});

		right?.addEventListener('click', () => {
			const hidden = root.toggleAttribute('data-user-hide-right');
			try {
				localStorage.setItem(KEY_RIGHT, hidden ? '1' : '0');
			} catch {}
			sync(right, 'data-user-hide-right');
		});
	}

	initSidebarToggles();
	document.addEventListener('astro:page-load', initSidebarToggles);
</script>

<script>
	// Всплывающие карточки «Что это?» для аббревиатур (см. rehypeGlossary + glossary.js).
	import { glossary } from '../data/glossary.js';

	function initGlossary() {
		if (window.__eduGlossaryReady) return;
		window.__eduGlossaryReady = true;

		const defs = new Map(glossary.map((g) => [g.term, g]));
		let pop = null;
		let pinned = false;
		let currentEl = null;

		function ensurePop() {
			if (pop) return pop;
			pop = document.createElement('div');
			pop.className = 'glossary-popover';
			pop.setAttribute('role', 'dialog');
			pop.innerHTML =
				'<button type="button" class="glossary-popover__close" aria-label="Закрыть">×</button>' +
				'<div class="glossary-popover__title">Что это?</div>' +
				'<div class="glossary-popover__head"><span class="glossary-popover__term"></span><span class="glossary-popover__full"></span></div>' +
				'<div class="glossary-popover__def"></div>';
			document.body.appendChild(pop);
			pop.querySelector('.glossary-popover__close').addEventListener('click', (e) => {
				e.stopPropagation();
				hide();
			});
			return pop;
		}

		function position(el) {
			const r = el.getBoundingClientRect();
			const pw = pop.offsetWidth;
			const ph = pop.offsetHeight;
			let left = r.left;
			if (left + pw > window.innerWidth - 12) left = window.innerWidth - pw - 12;
			if (left < 12) left = 12;
			let top = r.bottom + 8;
			if (top + ph > window.innerHeight - 12) top = r.top - ph - 8;
			if (top < 12) top = 12;
			pop.style.left = left + 'px';
			pop.style.top = top + 'px';
		}

		function show(el) {
			const term = el.getAttribute('data-term');
			const entry = defs.get(term);
			if (!entry) return;
			const p = ensurePop();
			p.querySelector('.glossary-popover__term').textContent = term;
			p.querySelector('.glossary-popover__full').textContent = entry.full ? ' — ' + entry.full : '';
			p.querySelector('.glossary-popover__def').textContent = entry.def;
			p.style.display = 'block';
			position(el);
		}

		function hide() {
			if (pop) pop.style.display = 'none';
			pinned = false;
			currentEl = null;
		}

		document.addEventListener('click', (e) => {
			const term = e.target.closest && e.target.closest('.glossary-term');
			if (term) {
				e.preventDefault();
				if (pinned && currentEl === term) {
					hide();
				} else {
					show(term);
					pinned = true;
					currentEl = term;
				}
				return;
			}
			if (pop && pop.style.display === 'block' && !(e.target.closest && e.target.closest('.glossary-popover'))) {
				hide();
			}
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') hide();
		});

		if (window.matchMedia && window.matchMedia('(hover: hover)').matches) {
			document.addEventListener('mouseover', (e) => {
				const t = e.target.closest && e.target.closest('.glossary-term');
				if (t && !pinned) {
					show(t);
					currentEl = t;
				}
			});
			document.addEventListener('mouseout', (e) => {
				const t = e.target.closest && e.target.closest('.glossary-term');
				if (t && !pinned) hide();
			});
		}

		window.addEventListener('scroll', () => { if (!pinned) hide(); }, { passive: true });
	}

	initGlossary();
	document.addEventListener('astro:page-load', initGlossary);
</script>
